# Azure/Entra Configuration
TENANT_ID=your-tenant-id
CLIENT_ID=your-app-client-id
CLIENT_SECRET=your-app-client-secret-from-keyvault

# Shared Mailbox Configuration
SHARED_MAILBOX_EMAIL=epm-approvals@company.com
SHARED_MAILBOX_ID=mailbox-object-id

# Service Configuration
POLL_INTERVAL_MINUTES=5
TOKEN_EXPIRY_MINUTES=1440
WEBHOOK_URL=https://your-function-app.azurewebsites.net/api/approve

# Logging
LOG_LEVEL=info

# State Management
STATE_STORAGE_TYPE=blob
STATE_STORAGE_CONNECTION=DefaultEndpointsProtocol=https;...

# Application
NODE_ENV=production
